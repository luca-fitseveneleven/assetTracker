# Database
DATABASE_URL=postgresql://user:password@localhost:5432/assettracker

# PostgreSQL schema name (default: assettool)
# Set to "public" if your database uses the default schema
# DB_SCHEMA=assettool

# For Supabase or cloud databases, SSL is auto-detected from URL
# Set explicitly if using other cloud providers:
# DATABASE_SSL=true

# Encryption at Rest
# A 64-character hex string (32 bytes) used for AES-256-GCM encryption of
# sensitive data in the database. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# BetterAuth
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-super-secret-key-here-generate-with-openssl-rand-base64-32

# Demo Mode (optional - shows demo banner and enables demo features)
# DEMO_MODE=true

# ==============================================================================
# Feature Flags (all enabled by default)
# ==============================================================================

# Rate Limiting - Enable/disable rate limiting on API endpoints
# Default: true
# FEATURE_RATE_LIMITING=true

# Account Lockout - Lock accounts after failed login attempts
# Default: true (5 attempts, 15 min lockout)
# FEATURE_ACCOUNT_LOCKOUT=true

# Session Timeout - Expire sessions after inactivity
# Default: true (30 min inactivity timeout)
# FEATURE_SESSION_TIMEOUT=true

# Audit Logging - Log security-related events
# Default: true
# FEATURE_AUDIT_LOGGING=true 

# Email Notifications - Send email notifications for events
# Default: false (requires email provider setup)
# FEATURE_EMAIL_NOTIFICATIONS=false

# Advanced Search - Enable advanced search features
# Default: true
# FEATURE_ADVANCED_SEARCH=true

# Maintenance Mode - Show maintenance page to users
# Default: false
# MAINTENANCE_MODE=false

# Self-Hosted Mode - Skip SaaS landing page, go straight to login
# Default: false
# SELF_HOSTED=true

# ==============================================================================
# Microsoft Entra ID (Azure AD) SSO (Optional)
# ==============================================================================

# Register an app in Azure Portal > Microsoft Entra ID > App registrations
# Redirect URI: {BETTER_AUTH_URL}/api/auth/oauth2/callback/microsoft
# MICROSOFT_CLIENT_ID=your-application-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret-value
# MICROSOFT_TENANT_ID=your-tenant-id   # or "common" for multi-tenant

# ==============================================================================
# Cloudflare Turnstile CAPTCHA (Optional - for login protection)
# ==============================================================================

# Get your keys at https://dash.cloudflare.com/?to=/:account/turnstile
# If not set, CAPTCHA is disabled and login works normally.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAA...

# ==============================================================================
# Rate Limiting (Optional - Upstash Redis for distributed deployments)
# ==============================================================================

# In-memory rate limiting is enabled by default for single-instance deployments.
# For distributed deployments, configure Upstash Redis:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ==============================================================================
# Redis Caching (Optional - Upstash Redis for distributed caching)
# ==============================================================================

# When set, the caching layer uses Upstash Redis instead of in-memory.
# In-memory caching is used by default and works fine for single-instance deployments.
# REDIS_URL=https://your-instance.upstash.io
# REDIS_TOKEN=your-upstash-redis-token

# Optional: Cron Secret for demo reset endpoint
# CRON_SECRET=your-cron-secret-here

# ==============================================================================
# Email Provider Configuration (choose ONE provider)
# Configure via Admin Settings UI or environment variables
# ==============================================================================

# Email Provider: brevo, sendgrid, mailgun, postmark, or ses
# EMAIL_PROVIDER=brevo

# Brevo (formerly Sendinblue) - Free tier: 300 emails/day
# BREVO_API_KEY=your_brevo_api_key

# SendGrid - Free tier: 100 emails/day
# SENDGRID_API_KEY=your_sendgrid_api_key

# Mailgun - Pay as you go
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.yourdomain.com

# Postmark - Free tier: 100 emails/month
# POSTMARK_API_KEY=your_postmark_api_key

# Amazon SES - Pay as you go (very cheap)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# Common Email Settings
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Asset Tracker

# ==============================================================================
# File Storage (Optional - for asset attachments & photos)
# ==============================================================================

# Storage Provider: local (default), s3, or azure
# STORAGE_PROVIDER=local

# S3-compatible storage (AWS S3, MinIO, Backblaze B2, etc.)
# STORAGE_BUCKET=your-bucket-name
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=your_access_key
# STORAGE_SECRET_KEY=your_secret_key
# STORAGE_ENDPOINT=https://s3.example.com  # For S3-compatible (MinIO, B2, etc.)

# Azure Blob Storage
# STORAGE_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# STORAGE_AZURE_CONTAINER=attachments

# ==============================================================================
# Freshdesk Integration (Optional - for IT Tickets)
# Configure via Admin Settings UI or environment variables
# ==============================================================================

# Freshdesk domain (e.g., "yourcompany" for yourcompany.freshdesk.com)
# FRESHDESK_DOMAIN=yourcompany

# Freshdesk API key (found in Profile Settings > API Key)
# FRESHDESK_API_KEY=your_freshdesk_api_key

# ==============================================================================
# Stripe Billing (Optional - for SaaS billing)
# ==============================================================================

# Stripe secret key (from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe publishable key (for client-side)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret (from webhook endpoint settings)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs for each plan tier
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
