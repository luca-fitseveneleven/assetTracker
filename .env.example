# Database
DATABASE_URL=postgresql://user:password@localhost:5432/assettracker

# For Supabase or cloud databases, SSL is auto-detected from URL
# Set explicitly if using other cloud providers:
# DATABASE_SSL=true

# NextAuth
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here-generate-with-openssl-rand-base64-32

# Demo Mode (optional - shows demo banner and enables demo features)
# DEMO_MODE=true

# Optional: Rate Limiting (if using Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Cron Secret for demo reset endpoint
# CRON_SECRET=your-cron-secret-here
