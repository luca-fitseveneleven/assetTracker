{
  "name": "asset-tracker",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev --turbopack",
    "build": "node prisma/set-schema.mjs && prisma generate && prisma migrate deploy && next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/",
    "db:seed": "prisma db seed",
    "db:demo-seed": "node prisma/demo-seed.js",
    "db:demo-reset": "node scripts/reset-demo-db.mjs",
    "create-admin": "node scripts/create-admin.mjs",
    "test": "vitest run",
    "test:ui": "npx playwright test --ui",
    "test:mobile": "npx playwright test --project='Mobile Chrome'",
    "test:report": "npx playwright show-report",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:a11y": "playwright test accessibility"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@faker-js/faker": "^10.2.0",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-virtual": "^3.13.6",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "exceljs": "^4.4.0",
    "geist": "^1.5.1",
    "jsqr": "^1.4.0",
    "ldapjs": "^3.0.7",
    "lucide-react": "^1.0.1",
    "maplibre-gl": "^5.21.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "otplib": "^13.3.0",
    "pg": "^8.17.2",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "react-qr-code": "^2.0.13",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^8",
    "eslint-config-next": "^15.5.3",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
