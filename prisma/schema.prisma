generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Multi-tenancy: Organization model
model Organization {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(50)
  description String?
  settings    Json?
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)
  isActive    Boolean  @default(true)

  // Billing
  plan            String   @default("starter") @db.VarChar(20)
  stripeCustomerId    String?  @unique @db.VarChar(255)
  stripeSubscriptionId String? @unique @db.VarChar(255)
  trialEndsAt     DateTime? @db.Timestamp(6)
  maxAssets       Int      @default(100)
  maxUsers        Int      @default(3)

  // Relationships
  users       user[]
  departments Department[]
  assets      asset[]
  accessories accessories[]
  licences    licence[]
  consumables consumable[]
  roles       Role[]
  webhooks    Webhook[]

  @@map("organizations")
}

// Multi-tenancy: Department model (hierarchical)
model Department {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String       @db.VarChar(100)
  description    String?
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?      @db.Uuid
  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DepartmentHierarchy")
  createdAt      DateTime     @default(now()) @db.Timestamp(6)
  updatedAt      DateTime     @updatedAt @db.Timestamp(6)

  // Relationships
  users user[]

  @@index([organizationId])
  @@index([parentId])
  @@map("departments")
}

// RBAC: Role model
model Role {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String        @db.VarChar(100)
  description    String?
  permissions    String[]
  isSystem       Boolean       @default(false)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime      @updatedAt @db.Timestamp(6)

  userRoles UserRole[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("roles")
}

// RBAC: UserRole junction model
model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      user     @relation(fields: [userId], references: [userid], onDelete: Cascade)
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now()) @db.Timestamp(6)
  grantedBy String?  @db.Uuid

  @@unique([userId, roleId])
  @@map("user_roles")
}

// Webhook System
model Webhook {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String        @db.VarChar(100)
  url            String        @db.VarChar(500)
  secret         String?       @db.VarChar(255)
  events         String[]
  isActive       Boolean       @default(true)
  retryAttempts  Int           @default(3)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime      @updatedAt @db.Timestamp(6)

  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@index([isActive])
  @@index([organizationId, isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookId   String   @db.Uuid
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String   @db.VarChar(100)
  payload     Json
  statusCode  Int?
  response    String?
  attempt     Int      @default(1)
  success     Boolean  @default(false)
  deliveredAt DateTime @default(now()) @db.Timestamp(6)
  error       String?

  @@index([webhookId])
  @@index([deliveredAt])
  @@map("webhook_deliveries")
}

// Asset Reservation/Booking System
model AssetReservation {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId    String    @db.Uuid
  asset      asset     @relation(fields: [assetId], references: [assetid], onDelete: Cascade)
  userId     String    @db.Uuid
  user       user      @relation(fields: [userId], references: [userid], onDelete: Cascade)
  startDate  DateTime  @db.Timestamp(6)
  endDate    DateTime  @db.Timestamp(6)
  status     String    @default("pending") @db.VarChar(20)
  notes      String?
  approvedBy String?   @db.Uuid
  approvedAt DateTime? @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@index([assetId, status])
  @@map("asset_reservations")
}

// Asset Transfer Log
model AssetTransfer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId         String    @db.Uuid
  asset           asset     @relation(fields: [assetId], references: [assetid], onDelete: Cascade)
  transferType    String    @db.VarChar(20) // user, location, organization
  fromUserId      String?   @db.Uuid
  toUserId        String?   @db.Uuid
  fromLocationId  String?   @db.Uuid
  toLocationId    String?   @db.Uuid
  fromOrgId       String?   @db.Uuid
  toOrgId         String?   @db.Uuid
  reason          String?
  transferredBy   String    @db.Uuid
  transferredAt   DateTime  @default(now()) @db.Timestamp(6)

  @@index([assetId])
  @@index([transferredAt])
  @@map("asset_transfers")
}

// Approval Workflow
model ApprovalRequest {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String    @db.VarChar(50) // reservation, asset_request, transfer
  entityId    String    @db.Uuid
  requesterId String    @db.Uuid
  requester   user      @relation("approval_requester", fields: [requesterId], references: [userid], onDelete: Cascade)
  approverId  String?   @db.Uuid
  approver    user?     @relation("approval_approver", fields: [approverId], references: [userid])
  status      String    @default("pending") @db.VarChar(20) // pending, approved, rejected
  notes       String?
  resolvedAt  DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)

  @@index([requesterId])
  @@index([status])
  @@index([approverId])
  @@map("approval_requests")
}

// Automation Rules / Workflows Engine
model AutomationRule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  trigger     String   @db.VarChar(50) // warranty_expiring, maintenance_due, asset_status_change, license_expiring, stock_low
  conditions  String   @db.Text // JSON: conditions to evaluate
  actions     String   @db.Text // JSON: actions to take (notify, update_status, create_ticket, etc.)
  isActive    Boolean  @default(true)
  lastRunAt   DateTime? @db.Timestamp(6)
  runCount    Int      @default(0)
  createdBy   String   @db.Uuid
  creator     user     @relation("automation_creator", fields: [createdBy], references: [userid], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  @@index([trigger])
  @@index([isActive])
  @@map("automation_rules")
}

// Stock Alert Configuration
model StockAlert {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consumableId      String     @unique @db.Uuid
  consumable        consumable @relation(fields: [consumableId], references: [consumableid], onDelete: Cascade)
  minThreshold      Int        @default(10)
  criticalThreshold Int        @default(5)
  emailNotify       Boolean    @default(true)
  webhookNotify     Boolean    @default(false)
  lastAlertSentAt   DateTime?  @db.Timestamp(6)
  createdAt         DateTime   @default(now()) @db.Timestamp(6)
  updatedAt         DateTime   @updatedAt @db.Timestamp(6)

  @@map("stock_alerts")
}

// Bulk Import Jobs
model ImportJob {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  user          user      @relation(fields: [userId], references: [userid], onDelete: Cascade)
  entityType    String    @db.VarChar(50)
  fileName      String    @db.VarChar(255)
  fileSize      Int
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  successCount  Int       @default(0)
  errorCount    Int       @default(0)
  status        String    @default("pending") @db.VarChar(20)
  errors        Json?
  startedAt     DateTime? @db.Timestamp(6)
  completedAt   DateTime? @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @db.Timestamp(6)

  @@index([userId])
  @@map("import_jobs")
}

model accessorieCategoryType {
  accessoriecategorytypeid   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accessoriecategorytypename String        @db.VarChar
  accessories                accessories[]
}

model accessories {
  accessorieid             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accessoriename           String                 @db.VarChar
  accessorietag            String                 @db.VarChar
  purchaseprice            Decimal?               @db.Decimal(10, 2)
  purchasedate             DateTime?              @db.Date
  requestable              Boolean?
  manufacturerid           String                 @db.Uuid
  statustypeid             String                 @db.Uuid
  accessoriecategorytypeid String                 @db.Uuid
  locationid               String                 @db.Uuid
  supplierid               String                 @db.Uuid
  modelid                  String                 @db.Uuid
  organizationId           String?                @db.Uuid
  creation_date            DateTime               @db.Timestamp(6)
  change_date              DateTime?              @db.Timestamp(6)
  accessorieCategoryType   accessorieCategoryType @relation(fields: [accessoriecategorytypeid], references: [accessoriecategorytypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_accessoriecategorytype_c_accessoriecategorytypei")
  location                 location               @relation(fields: [locationid], references: [locationid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_location_c_locationid")
  manufacturer             manufacturer           @relation(fields: [manufacturerid], references: [manufacturerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_manufacturer_c_manufacturerid")
  model                    model                  @relation(fields: [modelid], references: [modelid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_model_c_modelid")
  organization             Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statusType               statusType             @relation(fields: [statustypeid], references: [statustypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_statustype_c_statustypeid")
  supplier                 supplier               @relation(fields: [supplierid], references: [supplierid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accessories_supplier_c_supplierid")
  userAccessoires          userAccessoires[]

  @@index([organizationId])
  @@index([manufacturerid])
  @@index([statustypeid])
  @@index([accessoriecategorytypeid])
  @@index([locationid])
  @@index([supplierid])
  @@index([modelid])
}

model accounts {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [userid], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model asset {
  assetid               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetname             String                  @db.VarChar
  assettag              String                  @unique @db.VarChar
  serialnumber          String                  @unique @db.VarChar
  modelid               String?                 @db.Uuid
  specs                 String?
  notes                 String?
  purchaseprice         Decimal?                @db.Decimal(10, 2)
  purchasedate          DateTime?               @db.Date
  mobile                Boolean?
  requestable           Boolean?
  assetcategorytypeid   String?                 @db.Uuid
  statustypeid          String?                 @db.Uuid
  supplierid            String?                 @db.Uuid
  locationid            String?                 @db.Uuid
  manufacturerid        String?                 @db.Uuid
  organizationId        String?                 @db.Uuid
  creation_date         DateTime                @db.Timestamp(6)
  change_date           DateTime?               @db.Timestamp(6)
  expectedEndOfLife     DateTime?               @db.Date
  warrantyExpires       DateTime?               @db.Date
  warrantyMonths        Int?
  assetCategoryType     assetCategoryType?      @relation(fields: [assetcategorytypeid], references: [assetcategorytypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_assetcategorytype_c_assetcategorytypeid")
  location              location?               @relation(fields: [locationid], references: [locationid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_location_c_locationid")
  manufacturer          manufacturer?           @relation(fields: [manufacturerid], references: [manufacturerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_manufacturer_c_manufacturerid")
  model                 model?                  @relation(fields: [modelid], references: [modelid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_model_c_modelid")
  organization          Organization?           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statusType            statusType?             @relation(fields: [statustypeid], references: [statustypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_statustype_c_statustypeid")
  supplier              supplier?               @relation(fields: [supplierid], references: [supplierid], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_supplier_c_supplierid")
  asset_attachments     asset_attachments[]
  maintenance_schedules maintenance_schedules[]
  reservations          AssetReservation[]
  transfers             AssetTransfer[]
  userAssets            userAssets[]

  @@index([assetname])
  @@index([statustypeid])
  @@index([assetcategorytypeid])
  @@index([locationid])
  @@index([organizationId])
  @@index([creation_date])
  @@index([modelid])
  @@index([supplierid])
  @@index([manufacturerid])
  @@index([organizationId, creation_date])
}

model assetCategoryType {
  assetcategorytypeid   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetcategorytypename String                 @db.VarChar
  asset                 asset[]
  depreciation_settings depreciation_settings?
}

model asset_attachments {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId      String   @db.Uuid
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  mimeType     String   @db.VarChar(100)
  size         Int
  path         String   @db.VarChar(500)
  isPrimary    Boolean  @default(false)
  uploadedBy   String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  asset        asset    @relation(fields: [assetId], references: [assetid], onDelete: Cascade)
  user         user?    @relation(fields: [uploadedBy], references: [userid])

  @@index([assetId])
}

model audit_logs {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  String?  @db.Uuid
  details   String?
  ipAddress String?  @db.VarChar(50)
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  user      user?    @relation(fields: [userId], references: [userid])

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@index([userId, createdAt])
}

model consumable {
  consumableid             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consumablename           String                 @db.VarChar
  consumablecategorytypeid String                 @db.Uuid
  manufacturerid           String                 @db.Uuid
  supplierid               String                 @db.Uuid
  purchaseprice            Decimal?               @db.Decimal(10, 2)
  purchasedate             DateTime?              @db.Date
  organizationId           String?                @db.Uuid
  creation_date            DateTime               @db.Timestamp(6)
  change_date              DateTime?              @db.Timestamp(6)
  minQuantity              Int                    @default(0)
  quantity                 Int                    @default(0)
  consumableCategoryType   consumableCategoryType @relation(fields: [consumablecategorytypeid], references: [consumablecategorytypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_consumable_consumablecategorytype_c_consumablecategorytypeid")
  manufacturer             manufacturer           @relation(fields: [manufacturerid], references: [manufacturerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_consumable_manufacturer_c_manufacturerid")
  organization             Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier                 supplier               @relation(fields: [supplierid], references: [supplierid], onDelete: NoAction, onUpdate: NoAction, map: "fk_consumable_supplier_c_supplierid")
  stockAlert               StockAlert?
  consumable_checkouts     consumable_checkouts[]

  @@index([consumablename])
  @@index([organizationId])
  @@index([manufacturerid])
  @@index([supplierid])
  @@index([consumablecategorytypeid])
  @@index([organizationId, consumablename])
}

model consumableCategoryType {
  consumablecategorytypeid   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consumablecategorytypename String       @db.VarChar
  consumable                 consumable[]
}

model custom_field_definitions {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @db.VarChar(100)
  fieldType           String                @db.VarChar(20)
  options             String?
  isRequired          Boolean               @default(false)
  entityType          String                @db.VarChar(50)
  displayOrder        Int                   @default(0)
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now()) @db.Timestamp(6)
  updatedAt           DateTime              @db.Timestamp(6)
  custom_field_values custom_field_values[]

  @@index([entityType])
  @@index([isActive])
}

model custom_field_values {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fieldId                  String                   @db.Uuid
  entityId                 String                   @db.Uuid
  value                    String?
  createdAt                DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt                DateTime                 @db.Timestamp(6)
  custom_field_definitions custom_field_definitions @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId])
}

model depreciation_settings {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId        String            @unique @db.Uuid
  method            String            @db.VarChar(30)
  usefulLifeYears   Int               @default(5)
  salvagePercent    Decimal           @default(10) @db.Decimal(5, 2)
  createdAt         DateTime          @default(now()) @db.Timestamp(6)
  updatedAt         DateTime          @db.Timestamp(6)
  assetCategoryType assetCategoryType @relation(fields: [categoryId], references: [assetcategorytypeid], onDelete: Cascade)
}

model email_templates {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(255)
  body      String
  variables String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @db.Timestamp(6)
}

model label_templates {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  width       Decimal  @db.Decimal(5, 2)
  height      Decimal  @db.Decimal(5, 2)
  layout      String
  includeQR   Boolean  @default(true)
  includeLogo Boolean  @default(false)
  fields      String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @db.Timestamp(6)
}

model licence {
  licenceid             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  licencekey            String?             @unique @db.VarChar
  licenceduserid        String?             @db.Uuid
  licensedtoemail       String?             @db.VarChar
  purchaseprice         Decimal?            @db.Decimal(10, 2)
  purchasedate          DateTime?           @db.Date
  expirationdate        DateTime?           @db.Date
  notes                 String?
  requestable           Boolean?
  licencecategorytypeid String              @db.Uuid
  manufacturerid        String              @db.Uuid
  supplierid            String              @db.Uuid
  organizationId        String?             @db.Uuid
  creation_date         DateTime            @db.Timestamp(6)
  change_date           DateTime?           @db.Timestamp(6)
  licenceCategoryType   licenceCategoryType @relation(fields: [licencecategorytypeid], references: [licencecategorytypeid], onDelete: NoAction, onUpdate: NoAction, map: "fk_licence_licencecategorytype_c_licencecategorytypeid")
  manufacturer          manufacturer        @relation(fields: [manufacturerid], references: [manufacturerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_licence_manufacturer_c_manufacturerid")
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier              supplier            @relation(fields: [supplierid], references: [supplierid], onDelete: NoAction, onUpdate: NoAction, map: "fk_licence_supplier_c_supplierid")
  user                  user?               @relation(fields: [licenceduserid], references: [userid], onDelete: NoAction, onUpdate: NoAction, map: "fk_licence_user_c_licenceduser_userid")

  @@index([organizationId])
  @@index([licenceduserid])
  @@index([manufacturerid])
  @@index([supplierid])
  @@index([licencecategorytypeid])
  @@index([expirationdate])
  @@index([organizationId, expirationdate])
}

model licenceCategoryType {
  licencecategorytypeid   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  licencecategorytypename String    @db.VarChar
  licence                 licence[]
}

model location {
  locationid    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationname  String?       @db.VarChar
  street        String?       @db.VarChar
  housenumber   String?       @db.VarChar
  city          String?       @db.VarChar
  country       String?       @db.VarChar
  creation_date DateTime      @db.Timestamp(6)
  change_date   DateTime?     @db.Timestamp(6)
  accessories   accessories[]
  asset         asset[]
}

model maintenance_logs {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId            String                @db.Uuid
  completedBy           String?               @db.Uuid
  completedAt           DateTime              @default(now()) @db.Timestamp(6)
  notes                 String?
  actualCost            Decimal?              @db.Decimal(10, 2)
  createdAt             DateTime              @default(now()) @db.Timestamp(6)
  user                  user?                 @relation(fields: [completedBy], references: [userid])
  maintenance_schedules maintenance_schedules @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([completedBy])
}

model maintenance_schedules {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId          String             @db.Uuid
  title            String             @db.VarChar(255)
  description      String?
  frequency        String             @db.VarChar(20)
  nextDueDate      DateTime           @db.Date
  lastCompletedAt  DateTime?          @db.Timestamp(6)
  assignedTo       String?            @db.Uuid
  estimatedCost    Decimal?           @db.Decimal(10, 2)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  updatedAt        DateTime           @db.Timestamp(6)
  maintenance_logs maintenance_logs[]
  asset            asset              @relation(fields: [assetId], references: [assetid], onDelete: Cascade)
  user             user?              @relation(fields: [assignedTo], references: [userid])

  @@index([nextDueDate])
  @@index([assetId])
  @@index([assignedTo])
  @@index([isActive])
  @@index([isActive, nextDueDate])
}

model manufacturer {
  manufacturerid   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manufacturername String        @db.VarChar
  creation_date    DateTime      @db.Timestamp(6)
