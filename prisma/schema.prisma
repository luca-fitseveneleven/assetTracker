  scopeType      String    @default("all") @db.VarChar(20) // all, location, category
  scopeId        String?   @db.Uuid
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @db.Timestamp(6)

  auditors       AuditCampaignAuditor[]
  entries        AuditEntry[]

  @@index([organizationId])
  @@index([status])
  @@index([createdBy])
  @@map("audit_campaigns")
}

// Phase 3B: Audit Campaign Auditors
model AuditCampaignAuditor {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String        @db.Uuid
  campaign   AuditCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String        @db.Uuid
  user       user          @relation(fields: [userId], references: [userid], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("audit_campaign_auditors")
}

// Phase 3B: Audit Entries (one per asset per campaign)
model AuditEntry {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String        @db.Uuid
  campaign   AuditCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assetId    String        @db.Uuid
  asset      asset         @relation(fields: [assetId], references: [assetid], onDelete: Cascade)
  status     String        @default("unscanned") @db.VarChar(20) // unscanned, found, missing, moved
  auditedBy  String?       @db.Uuid
  auditor    user?         @relation("audit_entry_auditor", fields: [auditedBy], references: [userid])
  auditedAt  DateTime?     @db.Timestamp(6)
  locationId String?       @db.Uuid
  location   location?     @relation(fields: [locationId], references: [locationid])
  notes      String?

  @@unique([campaignId, assetId])
  @@index([campaignId])
  @@index([assetId])
  @@index([status])
  @@map("audit_entries")
}

// Phase 4A: LDAP Sync Log
model LdapSyncLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status            String   @db.VarChar(20) // success, failed, partial
  usersCreated      Int      @default(0)
  usersUpdated      Int      @default(0)
  usersDeactivated  Int      @default(0)
  errors            Json?
  triggeredBy       String?  @db.VarChar(50) // cron, manual, api
  durationMs        Int?
  createdAt         DateTime @default(now()) @db.Timestamp(6)

  @@index([createdAt])
  @@map("ldap_sync_logs")
}

// Customizable Dashboard Widgets
model DashboardWidget {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  user       user     @relation(fields: [userId], references: [userid], onDelete: Cascade)
  widgetType String   @db.VarChar(50) // stats, assetsByStatus, recentActivity, upcomingMaintenance, expiringLicences, costOverview
  position   Int
  visible    Boolean  @default(true)
  config     Json?
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @db.Timestamp(6)

  @@index([userId])
  @@index([userId, position])
  @@map("dashboard_widgets")
}
