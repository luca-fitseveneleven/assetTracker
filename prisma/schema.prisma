  checkedOutTo          String?   @db.Uuid
  checkedOutToUser      user?     @relation("checkout_to", fields: [checkedOutTo], references: [userid], onDelete: Cascade)
  checkedOutToLocationId String?  @db.Uuid
  checkedOutToLocation  location? @relation("checkout_to_location", fields: [checkedOutToLocationId], references: [locationid])
  checkedOutToAssetId   String?   @db.Uuid
  checkedOutToAsset     asset?    @relation("checkout_to_asset", fields: [checkedOutToAssetId], references: [assetid])
  checkedOutBy          String    @db.Uuid
  checkedOutByUser      user      @relation("checkout_by", fields: [checkedOutBy], references: [userid], onDelete: Cascade)
  checkoutDate          DateTime  @default(now()) @db.Timestamp(6)
  expectedReturn        DateTime? @db.Timestamp(6)
  returnDate            DateTime? @db.Timestamp(6)
  notes                 String?
  status                String    @default("checked_out") @db.VarChar(20) // checked_out, returned, overdue
  createdAt             DateTime  @default(now()) @db.Timestamp(6)
  updatedAt             DateTime  @updatedAt @db.Timestamp(6)
  eulaAcceptance        EulaAcceptance?

  @@index([assetId])
  @@index([checkedOutTo])
  @@index([checkedOutToLocationId])
  @@index([checkedOutToAssetId])
  @@index([status])
  @@index([assetId, status])
  @@map("asset_checkouts")
}

